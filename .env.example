# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-api-key-here

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
OLLAMA_BASE_URL=http://localhost:11434

# ── Per-stage model routing (ADR-032) — all optional, defaults to LLM_MODEL ──
# Validated: response_gen and memory on Haiku pass the full adversarial eval suite.
# Input gate, evaluators, proposer, and consequence engine remain on Sonnet.
#
# LLM_MODEL_RESPONSE_GEN=claude-haiku-4-5-20251001
# LLM_MODEL_MEMORY=claude-haiku-4-5-20251001
#
# The full four-stage Haiku config (input gate + evaluators) has not been fairly
# validated yet — see ADR-032 for context. Do not set LLM_MODEL_INPUT_GATE or
# LLM_MODEL_EVALUATORS without re-running the full adversarial eval suite first.

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev default):
DATABASE_URL=sqlite+aiosqlite:///sophia.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://sophia:sophia@postgres:5432/sophia

# ── Memory ───────────────────────────────────────────────────────────────────
MEMORY_PROVIDER=mock
SURREALDB_URL=ws://localhost:8529
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_NAMESPACE=sophia
SURREALDB_DATABASE=memory

# ── Hats ─────────────────────────────────────────────────────────────────────
DEFAULT_HAT=customer-service
HATS_DIR=./hats

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_ENABLED=false
# AUTH_BOOTSTRAP_KEY=  # Set to pre-seed a bootstrap key

# ── MCP Backends ─────────────────────────────────────────────────────────────
# Shopify MCP server (configure in hat backends block)
# SHOPIFY_MCP_URL=http://shopify-mcp:8080
# SHOPIFY_MCP_TOKEN=your-shopify-token

# ── Notifications ────────────────────────────────────────────────────────────
NOTIFICATION_PROVIDER=log
# NOTIFICATION_WEBHOOK_URL=https://hooks.example.com/notify

# ── Webhooks ─────────────────────────────────────────────────────────────────
# SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Consequence Tree ─────────────────────────────────────────────────────────
TREE_MAX_DEPTH=3
TREE_PRUNE_THRESHOLD=0.05
CATASTROPHIC_THRESHOLD=-0.8
