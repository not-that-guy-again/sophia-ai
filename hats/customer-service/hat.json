{
  "name": "customer-service",
  "version": "0.1.0",
  "display_name": "Customer Service",
  "description": "Handles customer inquiries, refunds, order management, and compensation for e-commerce businesses.",
  "author": "sophia-core",
  "license": "Apache-2.0",
  "sophia_version": ">=0.1.0",
  "tools": [
    "look_up_order",
    "check_order_status",
    "check_current_inventory",
    "place_new_order",
    "cancel_order",
    "look_up_customer",
    "get_customer_order_history",
    "track_shipment",
    "update_shipping_address",
    "look_up_product",
    "check_warranty_status",
    "initiate_return",
    "check_return_status",
    "offer_discount",
    "offer_free_shipping",
    "offer_partial_refund",
    "offer_full_refund",
    "send_replacement_product",
    "notify_manager",
    "request_approval",
    "escalate_to_human"
  ],
  "default_evaluator_weights": {
    "tribal": 0.40,
    "domain": 0.25,
    "self_interest": 0.20,
    "authority": 0.15
  },
  "risk_thresholds": {
    "green": -0.1,
    "yellow": -0.4,
    "orange": -0.7
  },
  "backends": {
    "order": { "provider": "mock", "config": {} },
    "customer": { "provider": "mock", "config": {} },
    "shipping": { "provider": "mock", "config": {} },
    "inventory": { "provider": "mock", "config": {} },
    "compensation": { "provider": "mock", "config": {} }
  },
  "webhooks": {
    "shopify": {
      "secret_env": "SHOPIFY_WEBHOOK_SECRET",
      "events": {
        "orders/create": { "action": "memory_update" },
        "orders/cancelled": { "action": "memory_update" },
        "orders/fulfilled": { "action": "memory_update" },
        "refunds/create": { "action": "memory_update" }
      }
    }
  },
  "communications": {
    "channels": {
      "slack": {
        "server_url_env": "SLACK_MCP_URL",
        "server_name": "slack-mcp",
        "auth_token_env": "SLACK_MCP_TOKEN"
      },
      "email": {
        "server_url_env": "GMAIL_MCP_URL",
        "server_name": "gmail-mcp",
        "auth_token_env": "GMAIL_MCP_TOKEN"
      }
    }
  },
  "ack_enabled": true,
  "ack_financial_ceiling": 0.0,
  "ack_templates": {
    "order_status": [
      "Let me pull up order {order_id} for you.",
      "Checking on that now — one moment.",
      "Got it, looking into order {order_id}."
    ],
    "refund_request": [
      "Let me look into that for you.",
      "One moment while I review this."
    ],
    "product_inquiry": [
      "Let me check on that for you.",
      "One moment while I look into that."
    ],
    "_default": [
      "One moment while I look into that.",
      "Let me check on that for you.",
      "Got it — looking into that now."
    ]
  }
}
